---
import BaseLayout from '@layouts/BaseLayout.astro';
import { t } from '@i18n/utils';
---

<BaseLayout title="404 — Alexandre Akira">
  <main id="main-content" class="flex min-h-screen items-center justify-center px-6">
    <div class="text-center">
      <p class="font-heading text-[clamp(6rem,20vw,12rem)] font-bold leading-none text-accent">
        404
      </p>
      <h1 class="mt-4 font-heading text-2xl font-bold text-text md:text-3xl">
        <span data-lang-show="en">{t('404.title', 'en')}</span>
        <span data-lang-show="pt">{t('404.title', 'pt')}</span>
      </h1>
      <p class="mt-3 max-w-md text-text-secondary">
        <span data-lang-show="en">{t('404.description', 'en')}</span>
        <span data-lang-show="pt">{t('404.description', 'pt')}</span>
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-btn border border-accent px-6 py-3 text-sm font-medium text-accent transition-colors hover:bg-accent/10"
      >
        <span data-lang-show="en">{t('404.back', 'en')}</span>
        <span data-lang-show="pt">{t('404.back', 'pt')}</span>
      </a>
    </div>
  </main>
</BaseLayout>
