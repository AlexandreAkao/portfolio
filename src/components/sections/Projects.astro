---
import T from '@components/ui/T.astro';
import { projects } from '@data/projects';
import ScrollReveal from '@components/islands/ScrollReveal.tsx';
import { Icon } from 'astro-icon/components';

const professional = projects.filter((p) => p.type === 'professional');
const personal = projects.filter((p) => p.type === 'personal');
---

<section id="projects" class="py-20">
  <div class="mx-auto max-w-4xl px-6">
    <ScrollReveal client:visible>
      <h2 class="mb-12 text-center font-heading text-3xl font-bold text-text">
        <span class="section-tag"><T k="projects.title" /></span>
      </h2>
    </ScrollReveal>

    <ScrollReveal client:visible delay={0.1}>
      <h3 class="mb-6 font-heading text-xl font-semibold text-accent">
        <T k="projects.professional" />
      </h3>
    </ScrollReveal>
    <div class="mb-12 grid gap-6 md:grid-cols-2">
      {professional.map((project, i) => (
        <ScrollReveal client:visible delay={i * 0.1}>
          <div class="flex h-full flex-col rounded-card border border-border bg-card p-6 transition-colors hover:border-accent/50">
            <h4 class="mb-2 font-heading text-lg font-bold text-text">{project.title}</h4>
            <p class="mb-4 flex-1 text-sm text-text-secondary">
              <span data-lang-show="en">{project.description.en}</span>
              <span data-lang-show="pt">{project.description.pt}</span>
            </p>
            {project.metrics && (
              <p class="mb-3 text-xs font-semibold text-accent">{project.metrics}</p>
            )}
            <div class="flex flex-wrap gap-1">
              {project.tech.map((t) => (
                <span class="rounded-btn border border-border px-2 py-0.5 text-xs text-text-secondary">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>

    <ScrollReveal client:visible delay={0.1}>
      <h3 class="mb-6 font-heading text-xl font-semibold text-accent">
        <T k="projects.personal" />
      </h3>
    </ScrollReveal>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {personal.map((project, i) => (
        <ScrollReveal client:visible delay={i * 0.05}>
          <div class="flex h-full flex-col rounded-card border border-border bg-card p-6 transition-colors hover:border-accent/50">
            <div class="mb-3 flex items-center justify-between">
              <Icon name="lucide:folder" class="h-8 w-8 text-accent" />
              <div class="flex gap-3">
                {project.github && (
                  <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-text-secondary transition-colors hover:text-accent">
                    <Icon name="lucide:github" class="h-5 w-5" />
                  </a>
                )}
                {project.live && (
                  <a href={project.live} target="_blank" rel="noopener noreferrer" class="text-text-secondary transition-colors hover:text-accent">
                    <Icon name="lucide:external-link" class="h-5 w-5" />
                  </a>
                )}
              </div>
            </div>
            <h4 class="mb-2 font-heading text-lg font-bold text-text">{project.title}</h4>
            <p class="mb-4 flex-1 text-sm text-text-secondary">
              <span data-lang-show="en">{project.description.en}</span>
              <span data-lang-show="pt">{project.description.pt}</span>
            </p>
            <div class="flex flex-wrap gap-1">
              {project.tech.map((t) => (
                <span class="rounded-btn border border-border px-2 py-0.5 text-xs text-text-secondary">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>
