---
import { t } from '@i18n/utils';
import T from '@components/ui/T.astro';
import ScrollReveal from '@components/islands/ScrollReveal.tsx';

const stats = [
  { valueKey: 'about.stat.years', labelKey: 'about.stat.years.label' },
  { valueKey: 'about.stat.centers', labelKey: 'about.stat.centers.label' },
  { valueKey: 'about.stat.components', labelKey: 'about.stat.components.label' },
  { valueKey: 'about.stat.microservices', labelKey: 'about.stat.microservices.label' },
];
---

<section id="about" class="py-20">
  <div class="mx-auto max-w-4xl px-6">
    <ScrollReveal client:visible>
      <h2 class="mb-12 text-center font-heading text-3xl font-bold text-text">
        <span class="section-tag"><T k="about.title" /></span>
      </h2>
    </ScrollReveal>

    <ScrollReveal client:visible delay={0.1}>
      <div class="mb-8 flex justify-center">
        <img
          src="/images/avatar.jpeg"
          alt="Alexandre Akira"
          class="avatar-img h-32 w-32 rounded-full border-2 border-accent object-cover shadow-lg"
        />
      </div>
      <div class="mb-12 space-y-4 text-text-secondary">
        <p>
          <span data-lang-show="en">{t('about.p1', 'en')}</span>
          <span data-lang-show="pt">{t('about.p1', 'pt')}</span>
        </p>
        <p>
          <span data-lang-show="en">{t('about.p2', 'en')}</span>
          <span data-lang-show="pt">{t('about.p2', 'pt')}</span>
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal client:visible delay={0.2}>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
        {stats.map((stat) => (
          <div class="rounded-card border border-border bg-card p-4 text-center">
            <p class="font-heading text-2xl font-bold text-accent"><T k={stat.valueKey} /></p>
            <p class="text-sm text-text-secondary"><T k={stat.labelKey} /></p>
          </div>
        ))}
      </div>
    </ScrollReveal>
  </div>
</section>
