---
import { t } from '@i18n/utils';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  coverImage?: string;
  href: string;
  locale: 'en' | 'pt';
  readingTime: number;
}

const { title, description, date, tags, coverImage, href, locale, readingTime } = Astro.props;

const dateLocale = locale === 'pt' ? 'pt-BR' : 'en-US';
const formattedDate = date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' });
---

<a href={href} class="group block overflow-hidden rounded-card border border-border bg-card transition-all duration-300 hover:border-accent/50 hover:-translate-y-1 hover:shadow-lg hover:shadow-accent/5">
  {coverImage && (
    <img src={coverImage} alt={title} class="h-48 w-full object-cover" loading="lazy" decoding="async" />
  )}
  <div class="p-6">
    <div class="mb-1 flex items-center gap-2 text-sm">
      <time class="text-accent">{formattedDate}</time>
      <span class="text-text-secondary">·</span>
      <span class="text-text-secondary">{readingTime} {t('blog.minRead', locale)}</span>
    </div>
    <h2 class="mb-2 font-heading text-xl font-bold text-text transition-colors group-hover:text-accent">
      {title}
    </h2>
    <p class="text-text-secondary">{description}</p>
    {tags && (
      <div class="mt-3 flex flex-wrap gap-1">
        {tags.map((tag: string) => (
          <span class="rounded-btn border border-border px-2 py-0.5 text-xs text-text-secondary">
            {tag}
          </span>
        ))}
      </div>
    )}
    <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent transition-all group-hover:gap-2">
      {t('blog.read', locale)}
      <span aria-hidden="true">&rarr;</span>
    </span>
  </div>
</a>
