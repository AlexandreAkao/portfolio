---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Header from '@components/common/Header.astro';
import Footer from '@components/common/Footer.astro';
import T from '@components/ui/T.astro';
import { t } from '@i18n/utils';

interface RelatedPost {
  title: string;
  href: string;
  date: Date;
  tags?: string[];
}

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  coverImage?: ImageMetadata;
  lang: 'en' | 'pt';
  headings?: MarkdownHeading[];
  relatedPosts?: RelatedPost[];
}

const { title, description, date, tags, coverImage, lang, headings = [], relatedPosts = [] } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth <= 3);
const enDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const ptDate = date.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' });

const shareUrl = new URL(Astro.url.pathname, Astro.site).href;
const shareTitle = encodeURIComponent(title);
const shareUrlEncoded = encodeURIComponent(shareUrl);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site!.origin },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${Astro.site!.origin}/blog` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<BaseLayout
  title={`${title} - Alexandre Akira`}
  description={description}
  image={coverImage?.src}
  type="article"
  publishedTime={date.toISOString()}
  tags={tags}
  locale={lang}
>
  <!-- Reading progress bar -->
  <div id="reading-progress" class="fixed top-0 left-0 z-51 h-1 bg-accent" style="width: 0%" aria-hidden="true" />

  <Header />
  <main id="main-content" class="pt-24 pb-16">
    <article class="mx-auto max-w-5xl px-6">
      <!-- Breadcrumb navigation -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-1 text-sm text-text-secondary">
          <li>
            <a href="/" class="transition-colors hover:text-accent">
              <T k="nav.home" />
            </a>
          </li>
          <li aria-hidden="true" class="mx-1">/</li>
          <li>
            <a href="/blog" class="transition-colors hover:text-accent">
              <T k="nav.blog" />
            </a>
          </li>
          <li aria-hidden="true" class="mx-1">/</li>
          <li class="truncate text-text" aria-current="page">{title}</li>
        </ol>
      </nav>

      <!-- Breadcrumb structured data -->
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

      {coverImage && (
        <Image
          src={coverImage}
          alt={title}
          width={1024}
          height={340}
          class="mb-8 h-85 w-full rounded-lg object-cover"
          loading="eager"
          decoding="async"
        />
      )}

      <header class="mb-12">
        <p class="mb-2 text-sm text-accent">
          <span data-lang-show="en">{enDate}</span>
          <span data-lang-show="pt">{ptDate}</span>
        </p>
        <h1 class="mb-4 font-heading text-4xl font-bold text-text">{title}</h1>
        <p class="text-lg text-text-secondary">{description}</p>
        {tags && tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-btn border border-border px-2 py-0.5 text-xs text-accent">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      {tocHeadings.length > 2 && (
        <details class="toc group mb-10 rounded-sm border-l-4 border-accent bg-accent/4 p-0">
          <summary class="flex cursor-pointer list-none items-center gap-2 px-5 py-4 text-xs font-semibold uppercase tracking-widest text-accent [&::-webkit-details-marker]:hidden">
            <svg class="h-3.5 w-3.5 shrink-0 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
            <T k="blog.toc" />
          </summary>
          <nav aria-label="Table of contents" class="border-t border-accent/10 px-5 py-4">
            <ol class="space-y-2">
              {tocHeadings.map((h) => (
                <li class={h.depth === 3 ? 'ml-4' : ''}>
                  <a
                    href={`#${h.slug}`}
                    class:list={[
                      'inline-block text-text-secondary transition-colors hover:text-accent',
                      h.depth === 2 ? 'text-sm font-medium' : 'text-xs',
                    ]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      )}

      <div class="prose prose-invert max-w-none">
        <slot />
      </div>

      <!-- Social share buttons -->
      <div class="mt-12 border-t border-border pt-8">
        <p class="mb-4 text-sm font-medium text-text-secondary">
          <T k="blog.share" />
        </p>
        <div class="flex gap-3">
          <a
            href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrlEncoded}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-btn border border-border px-4 py-2 text-xs font-medium text-text-secondary transition-colors hover:border-accent hover:text-accent"
            aria-label="Share on X"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
            <span>X</span>
          </a>
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrlEncoded}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-btn border border-border px-4 py-2 text-xs font-medium text-text-secondary transition-colors hover:border-accent hover:text-accent"
            aria-label="Share on LinkedIn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>

      <!-- Related posts -->
      {relatedPosts.length > 0 && (
        <section class="mt-12 border-t border-border pt-8">
          <h2 class="mb-6 font-heading text-2xl font-bold text-text">
            <T k="blog.related" />
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((rp) => (
              <a
                href={rp.href}
                class="group rounded-card border border-border bg-card p-5 transition-all hover:border-accent/50 hover:-translate-y-0.5"
              >
                <h3 class="font-heading text-base font-semibold text-text transition-colors group-hover:text-accent">
                  {rp.title}
                </h3>
                <time class="mt-2 block text-xs text-text-secondary">
                  {rp.date.toLocaleDateString(lang === 'pt' ? 'pt-BR' : 'en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                {rp.tags && rp.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1">
                    {rp.tags.slice(0, 3).map((tag) => (
                      <span class="rounded-btn border border-border px-2 py-0.5 text-xs text-text-secondary">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </main>
  <Footer />
</BaseLayout>

<!-- Reading progress script -->
<script>
  document.addEventListener('astro:page-load', () => {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;

    const controller = new AbortController();

    const update = () => {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = h > 0 ? `${(window.scrollY / h) * 100}%` : '0%';
    };

    window.addEventListener('scroll', update, { passive: true, signal: controller.signal });
    update();

    document.addEventListener('astro:before-swap', () => controller.abort(), { once: true });
  });
</script>

<style>
  .prose {
    color: var(--text-secondary);
    font-size: 1.125rem;
    line-height: 1.85;
    letter-spacing: -0.003em;
  }

  /* Paragraphs */
  .prose :global(p) {
    margin-top: 1.5em;
    margin-bottom: 1.5em;
  }

  /* Headings */
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--text);
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  .prose :global(h2) {
    font-size: 1.75rem;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    padding-bottom: 0.4em;
    border-bottom: 1px solid var(--border);
  }
  .prose :global(h3) {
    font-size: 1.375rem;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }
  .prose :global(h4) {
    font-size: 1.125rem;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  /* Links */
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 0.2s;
  }
  .prose :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  /* Inline code */
  .prose :global(code) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.15em 0.4em;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    color: var(--accent);
    word-break: break-word;
  }

  /* Code blocks */
  .prose :global(pre) {
    background: var(--bg-secondary) !important;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 0.875rem;
    line-height: 1.7;
    -webkit-overflow-scrolling: touch;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  /* Blockquotes */
  .prose :global(blockquote) {
    border-left: 4px solid var(--accent);
    background: color-mix(in srgb, var(--bg-secondary) 60%, transparent);
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.25rem;
    margin: 2em 0;
    font-style: italic;
    color: var(--text);
  }
  .prose :global(blockquote p) {
    margin: 0.5em 0;
  }
  .prose :global(blockquote p:first-child) {
    margin-top: 0;
  }
  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Lists */
  .prose :global(ul) {
    list-style-type: disc;
    padding-left: 1.75rem;
    margin: 1.25em 0;
  }
  .prose :global(ol) {
    list-style-type: decimal;
    padding-left: 1.75rem;
    margin: 1.25em 0;
  }
  .prose :global(li) {
    margin: 0.4em 0;
    padding-left: 0.35em;
  }
  .prose :global(li::marker) {
    color: var(--accent);
    font-weight: 600;
  }
  /* Tighten space between list and immediately following code block */
  .prose :global(ul + pre),
  .prose :global(ol + pre) {
    margin-top: -0.5em;
  }
  .prose :global(ul ul),
  .prose :global(ol ol),
  .prose :global(ul ol),
  .prose :global(ol ul) {
    margin: 0.4em 0;
    list-style-type: circle;
  }

  /* Images */
  .prose :global(img) {
    border-radius: 8px;
    margin: 2em auto;
    display: block;
  }

  /* Horizontal rules */
  .prose :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--border),
      var(--accent),
      var(--border),
      transparent
    );
    margin: 3em 0;
  }

  /* Strong */
  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  /* Tables (if used) */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
    font-size: 0.95em;
  }
  .prose :global(th),
  .prose :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    text-align: left;
  }
  .prose :global(th) {
    background: var(--bg-secondary);
    color: var(--text);
    font-weight: 600;
  }

  /* First element has no top margin */
  .prose > :global(*:first-child) {
    margin-top: 0;
  }
</style>
