---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/common/Header.astro';
import Footer from '@components/common/Footer.astro';
import T from '@components/ui/T.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  coverImage?: string;
  lang: 'en' | 'pt';
}

const { title, description, date, tags, coverImage, lang } = Astro.props;
const enDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const ptDate = date.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} - Alexandre Akira`} description={description}>
  <Header />
  <main class="pt-24 pb-16">
    <article class="mx-auto max-w-5xl px-6">
      <a
        href="/blog"
        class="mb-8 inline-flex items-center gap-1 text-sm text-text-secondary transition-colors hover:text-accent"
      >
        &larr; <T k="blog.back" />
      </a>

      {coverImage && (
        <img
          src={coverImage}
          alt={title}
          class="mb-8 h-85 w-full rounded-lg object-cover"
        />
      )}

      <header class="mb-12">
        <p class="mb-2 text-sm text-accent">
          <span data-lang-show="en">{enDate}</span>
          <span data-lang-show="pt">{ptDate}</span>
        </p>
        <h1 class="mb-4 font-heading text-4xl font-bold text-text">{title}</h1>
        <p class="text-lg text-text-secondary">{description}</p>
        {tags && tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-btn border border-border px-2 py-0.5 text-xs text-accent">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose prose-invert max-w-none">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .prose {
    color: var(--text-secondary);
    font-size: 1.125rem;
    line-height: 1.85;
    letter-spacing: -0.003em;
  }

  /* Paragraphs */
  .prose :global(p) {
    margin-top: 1.5em;
    margin-bottom: 1.5em;
  }

  /* Headings */
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    color: var(--text);
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
  .prose :global(h2) {
    font-size: 1.75rem;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
    padding-bottom: 0.4em;
    border-bottom: 1px solid var(--border);
  }
  .prose :global(h3) {
    font-size: 1.375rem;
    margin-top: 2em;
    margin-bottom: 0.6em;
  }
  .prose :global(h4) {
    font-size: 1.125rem;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  /* Links */
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 0.2s;
  }
  .prose :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  /* Inline code */
  .prose :global(code) {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.15em 0.4em;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    color: var(--accent);
    word-break: break-word;
  }

  /* Code blocks */
  .prose :global(pre) {
    background: var(--bg-secondary) !important;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5em 0;
    font-size: 0.875rem;
    line-height: 1.7;
    -webkit-overflow-scrolling: touch;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  /* Blockquotes */
  .prose :global(blockquote) {
    border-left: 4px solid var(--accent);
    background: color-mix(in srgb, var(--bg-secondary) 60%, transparent);
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.25rem;
    margin: 2em 0;
    font-style: italic;
    color: var(--text);
  }
  .prose :global(blockquote p) {
    margin: 0.5em 0;
  }
  .prose :global(blockquote p:first-child) {
    margin-top: 0;
  }
  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Lists */
  .prose :global(ul) {
    list-style-type: disc;
    padding-left: 1.75rem;
    margin: 1.25em 0;
  }
  .prose :global(ol) {
    list-style-type: decimal;
    padding-left: 1.75rem;
    margin: 1.25em 0;
  }
  .prose :global(li) {
    margin: 0.4em 0;
    padding-left: 0.35em;
  }
  .prose :global(li::marker) {
    color: var(--accent);
    font-weight: 600;
  }
  /* Tighten space between list and immediately following code block */
  .prose :global(ul + pre),
  .prose :global(ol + pre) {
    margin-top: -0.5em;
  }
  .prose :global(ul ul),
  .prose :global(ol ol),
  .prose :global(ul ol),
  .prose :global(ol ul) {
    margin: 0.4em 0;
    list-style-type: circle;
  }

  /* Images */
  .prose :global(img) {
    border-radius: 8px;
    margin: 2em auto;
    display: block;
  }

  /* Horizontal rules */
  .prose :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--border),
      var(--accent),
      var(--border),
      transparent
    );
    margin: 3em 0;
  }

  /* Strong */
  .prose :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  /* Tables (if used) */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2em 0;
    font-size: 0.95em;
  }
  .prose :global(th),
  .prose :global(td) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    text-align: left;
  }
  .prose :global(th) {
    background: var(--bg-secondary);
    color: var(--text);
    font-weight: 600;
  }

  /* First element has no top margin */
  .prose > :global(*:first-child) {
    margin-top: 0;
  }
</style>
