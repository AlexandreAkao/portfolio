---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';
import AvantgardeCursor from '@components/designs/avantgarde/AvantgardeCursor.tsx';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Alexandre Akira - Senior Full-Stack Developer' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en" data-design="engineer" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@200,300,400,500,600,700&display=swap" />
    <ClientRouter />
    <script is:inline>
      (function() {
        var validDesigns = ['engineer','creative','avantgarde','editorial'];
        var d = localStorage.getItem('design') || 'engineer';
        if (validDesigns.indexOf(d) === -1) d = 'engineer';
        document.documentElement.dataset.design = d;

        var params = new URLSearchParams(window.location.search);
        var langParam = params.get('lang');
        var lang = langParam || localStorage.getItem('lang') || 'en';
        if (lang !== 'en' && lang !== 'pt') lang = 'en';
        document.documentElement.dataset.lang = lang;
        document.documentElement.lang = lang;
        localStorage.setItem('lang', lang);
      })();
      document.addEventListener('astro:after-swap', function() {
        var validDesigns = ['engineer','creative','avantgarde','editorial'];
        var d = localStorage.getItem('design') || 'engineer';
        if (validDesigns.indexOf(d) === -1) d = 'engineer';
        document.documentElement.dataset.design = d;
        var lang = localStorage.getItem('lang') || 'en';
        document.documentElement.dataset.lang = lang;
        document.documentElement.lang = lang;
      });
    </script>
  </head>
  <body class="min-h-screen grid-bg">
    <slot />
    <AvantgardeCursor client:load transition:persist />
  </body>
</html>
