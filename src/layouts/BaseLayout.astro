---
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';
import AvantgardeCursor from '@components/designs/avantgarde/AvantgardeCursor.tsx';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
  locale?: 'en' | 'pt';
}

const {
  title,
  description = 'Alexandre Akira - Senior Full-Stack Developer',
  image,
  type = 'website',
  publishedTime,
  tags,
  locale,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site!.origin;
const ogImage = image ? new URL(image, siteUrl).href : `${siteUrl}/images/avatar.jpeg`;

const jsonLd = type === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImage,
      datePublished: publishedTime,
      author: {
        '@type': 'Person',
        name: 'Alexandre Akira',
        url: siteUrl,
      },
      publisher: {
        '@type': 'Person',
        name: 'Alexandre Akira',
        url: siteUrl,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl.href,
      },
      ...(tags?.length ? { keywords: tags.join(', ') } : {}),
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Alexandre Akira',
      url: siteUrl,
      jobTitle: 'Senior Full-Stack Developer',
      image: `${siteUrl}/images/avatar.jpeg`,
      sameAs: [
        'https://github.com/alexandreakao',
        'https://www.linkedin.com/in/alexandre-akao/',
        'https://dev.to/alexandreakira',
      ],
    };
---

<html lang={locale || 'en'} data-design="avantgarde" data-lang={locale || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content="Alexandre Akira" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Alexandre Akira" />
    <meta property="og:locale" content={locale === 'pt' ? 'pt_BR' : 'en_US'} />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === 'article' && tags?.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="x-default" href={canonicalUrl.href} />
    <link rel="alternate" hreflang="en" href={canonicalUrl.href} />
    <link rel="alternate" hreflang="pt" href={`${canonicalUrl.href}${canonicalUrl.search ? '&' : '?'}lang=pt`} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@200,300,400,500,600,700&display=swap" />
    <ClientRouter />
    <script is:inline>
      (function() {
        try {
          var validDesigns = ['engineer','creative','avantgarde','editorial'];
          var d = localStorage.getItem('design') || 'avantgarde';
          if (validDesigns.indexOf(d) === -1) d = 'avantgarde';
          document.documentElement.dataset.design = d;

          var params = new URLSearchParams(window.location.search);
          var langParam = params.get('lang');
          var lang = langParam || localStorage.getItem('lang') || 'en';
          if (lang !== 'en' && lang !== 'pt') lang = 'en';
          document.documentElement.dataset.lang = lang;
          document.documentElement.lang = lang;
          localStorage.setItem('lang', lang);
        } catch(e) {}
      })();
      document.addEventListener('astro:after-swap', function() {
        try {
          var validDesigns = ['engineer','creative','avantgarde','editorial'];
          var d = localStorage.getItem('design') || 'avantgarde';
          if (validDesigns.indexOf(d) === -1) d = 'avantgarde';
          document.documentElement.dataset.design = d;
          var lang = localStorage.getItem('lang') || 'en';
          document.documentElement.dataset.lang = lang;
          document.documentElement.lang = lang;
        } catch(e) {}
      });
    </script>
  </head>
  <body class="min-h-screen grid-bg">
    <a
      href="#main-content"
      class="fixed left-4 top-4 z-100 -translate-y-20 rounded-btn bg-accent px-4 py-2 text-sm font-medium text-bg transition-transform focus:translate-y-0"
    >
      Skip to content
    </a>
    <slot />
    <AvantgardeCursor client:load transition:persist />
  </body>
</html>
